\u0926\u094d\u0926",helpSupport:"\u0938\u0939\u093e\u092f\u0924\u093e \u0914\u0930 \u0938\u092e\u0930\u094d\u0925\u0928",howCanWeHelp:"\u0939\u092e \u0906\u092a\u0915\u0940 \u0915\u0948\u0938\u0947 \u092e\u0926\u0926 \u0915\u0930 \u0938\u0915\u0924\u0947 \u0939\u0948\u0902?",bookingIssues:"\u092c\u0941\u0915\u093f\u0902\u0917 \u0938\u0947 \u091c\u0941\u0921\u093c\u0940 \u0938\u092e\u0938\u094d\u092f\u093e\u090f\u0902",paymentRefunds:"\u092d\u0941\u0917\u0924\u093e\u0928 \u0914\u0930 \u0930\u093f\u092b\u0902\u0921",providerFeedback:"\u0938\u0947\u0935\u093e \u092a\u094d\u0930\u0926\u093e\u0924\u093e \u092a\u094d\u0930\u0924\u093f\u0915\u094d\u0930\u093f\u092f\u093e",accountAccess:"\u0916\u093e\u0924\u093e \u090f\u0915\u094d\u0938\u0947\u0938",faqTitle:"\u0905\u0915\u094d\u0938\u0930 \u092a\u0942\u091b\u0947 \u091c\u093e\u0928\u0947 \u0935\u093e\u0932\u0947 \u092a\u094d\u0930\u0936\u094d\u0928",faq1_question:"\u092e\u0948\u0902 \u0905\u092a\u0928\u0940 \u092c\u0941\u0915\u093f\u0902\u0917 \u0915\u0948\u0938\u0947 \u0930\u0926\u094d\u0926 \u0915\u0930\u0942\u0902?",faq1_answer:"\u0906\u092a My Bookings \u0938\u0947\u0915\u094d\u0936\u0928 \u0938\u0947 \u0905\u092a\u0928\u0940 \u092c\u0941\u0915\u093f\u0902\u0917 \u0930\u0926\u094d\u0926 \u0915\u0930 \u0938\u0915\u0924\u0947 \u0939\u0948\u0902\u0964",faq2_question:"\u092e\u0941\u091d\u0947 \u0930\u093f\u092b\u0902\u0921 \u0915\u092c \u092e\u093f\u0932\u0947\u0917\u093e?",faq2_answer:"\u0930\u093f\u092b\u0902\u0921 \u0906\u092e\u0924\u094c\u0930 \u092a\u0930 5\u20137 \u0915\u093e\u0930\u094d\u092f \u0926\u093f\u0935\u0938\u094b\u0902 \u092e\u0947\u0902 \u092a\u094d\u0930\u094b\u0938\u0947\u0938 \u0939\u094b\u0924\u093e \u0939\u0948\u0964",faq3_question:"\u0915\u094d\u092f\u093e \u092e\u0948\u0902 \u0938\u0947\u0935\u093e \u092a\u094d\u0930\u0926\u093e\u0924\u093e \u092c\u0926\u0932 \u0938\u0915\u0924\u093e \u0939\u0942\u0901?",faq3_answer:"\u0939\u093e\u0901, \u0938\u0947\u0935\u093e \u0936\u0941\u0930\u0942 \u0939\u094b\u0928\u0947 \u0938\u0947 \u092a\u0939\u0932\u0947 \u0906\u092a \u092c\u0926\u0932\u093e\u0935 \u0915\u0930 \u0938\u0915\u0924\u0947 \u0939\u0948\u0902\u0964",faq4_question:"\u0915\u094d\u092f\u093e \u0915\u0948\u0902\u0938\u093f\u0932\u0947\u0936\u0928 \u0936\u0941\u0932\u094d\u0915 \u0932\u0917\u0924\u093e \u0939\u0948?",faq4_answer:"\u0938\u092e\u092f \u0915\u0947 \u0905\u0928\u0941\u0938\u093e\u0930 \u0936\u0941\u0932\u094d\u0915 \u0932\u0917 \u0938\u0915\u0924\u093e \u0939\u0948\u0964",stillNeedHelp:"\u0905\u092d\u0940 \u092d\u0940 \u092e\u0926\u0926 \u091a\u093e\u0939\u093f\u090f? \u0939\u092e\u093e\u0930\u0940 \u091f\u0940\u092e 24/7 \u0909\u092a\u0932\u092c\u094d\u0927 \u0939\u0948",chatWith:"\u091a\u0948\u091f \u0915\u0930\u0947\u0902",support:"\u0938\u092a\u094b\u0930\u094d\u091f",callUs:"\u0915\u0949\u0932 \u0915\u0930\u0947\u0902",bookingIssues:"\u092c\u0941\u0915\u093f\u0902\u0917 \u0938\u092e\u0938\u094d\u092f\u093e\u090f\u0902",bookingIssueQuestion:"\u092e\u0947\u0930\u0940 \u092c\u0941\u0915\u093f\u0902\u0917 \u0915\u0928\u094d\u092b\u0930\u094d\u092e \u0915\u094d\u092f\u094b\u0902 \u0928\u0939\u0940\u0902 \u0939\u0941\u0908?",bookingIssueDesc:"\u0906\u092a\u0915\u0940 \u092c\u0941\u0915\u093f\u0902\u0917 \u0907\u0928 \u0915\u093e\u0930\u0923\u094b\u0902 \u0938\u0947 \u0915\u0928\u094d\u092b\u0930\u094d\u092e \u0928\u0939\u0940\u0902 \u0939\u094b \u0938\u0915\u0924\u0940:",reason1:"\u092d\u0941\u0917\u0924\u093e\u0928 \u0935\u093f\u092b\u0932",reason2:"\u0938\u094d\u0932\u0949\u091f \u0909\u092a\u0932\u092c\u094d\u0927 \u0928\u0939\u0940\u0902",reason3:"\u0928\u0947\u091f\u0935\u0930\u094d\u0915 \u0924\u094d\u0930\u0941\u091f\u093f",reason4:"\u0938\u0947\u0935\u093e \u092a\u094d\u0930\u0926\u093e\u0924\u093e \u0926\u094d\u0935\u093e\u0930\u093e \u0930\u0926\u094d\u0926",bookingIssueFooter:"\u0915\u0943\u092a\u092f\u093e \u0905\u092a\u0928\u0940 \u092c\u0941\u0915\u093f\u0902\u0917 \u0938\u094d\u0925\u093f\u0924\u093f My Bookings \u092e\u0947\u0902 \u